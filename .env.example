NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# SERVER-SIDE ONLY.
# Never expose this in client components, browser code, NEXT_PUBLIC_* variables,
# logs, screenshots, or shared docs. This key bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional future error monitoring. Leave blank unless Sentry is installed/configured.
SENTRY_DSN=
